{
  "_version": "1.65.0",

  "sap.app": {
    "id": "demo.app",
    "type": "application",
    "title": "RFQ Demo"
  },

  "sap.ui": {
    "technology": "UI5"
  },

  "sap.ui5": {

    "rootView": {
      "viewName": "demo.app.view.App",
      "type": "XML",
      "async": true,
      "id": "app"
    },

    "dependencies": {
      "minUI5Version": "1.120",
      "libs": {
        "sap.m": {}
      }
    },

    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "viewPath": "demo.app.view",
        "controlId": "app",
        "controlAggregation": "pages",
        "async": true
      },

      "routes": [
        {
          "pattern": "",
          "name": "main",
          "target": "main"
        },
        {
          "pattern": "rfqDetails",
          "name": "rfqDetails",
          "target": "rfqDetails"
        }
      ],

      "targets": {
        "main": {
          "viewName": "App"
        },

        "rfqDetails": {
          "viewName": "RFQDetails"
        }
      }
    }
  }
}